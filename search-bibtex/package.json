{
  "name": "search-bibtex",
  "version": "0.1.0",
  "description": "Standalone CLI for extracting PDF metadata, searching paper records, and selecting BibTeX entries.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "bin": {
    "search-bibtex": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binary": "tsx scripts/build-binaries.ts current",
    "build:binaries": "tsx scripts/build-binaries.ts all",
    "build:bundle": "tsx scripts/build-binaries.ts bundle",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:e2e": "tsx scripts/e2e-pdfs.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "fast-xml-parser": "^5.8.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pdf-parse": "^1.1.5",
    "@yao-pkg/pkg": "^6.19.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
