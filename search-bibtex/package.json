{
  "name": "search-bibtex",
  "version": "0.1.0",
  "description": "Standalone CLI and Codex skill for extracting PDF metadata, searching paper records, and selecting BibTeX entries.",
  "type": "module",
  "bin": {
    "search-bibtex": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:e2e": "tsx scripts/e2e-pdfs.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "fast-xml-parser": "^5.8.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
